STREAMLIT_PORT=8502
EE_PROJECT=streamelit

# Optional paths. In local Windows use the real local paths; in container use
# the mounted paths below.
# APP_AUTH_CONFIG=/app/auth/config.yaml
# APP_GEO_PATH=/app/data/Geo.shp
# CODEBOOK_AUTH_CONFIG=/app/auth/config.yaml
# CODEBOOK_GEO_PATH=/app/data/Geo.shp

# Optional. If using a service account, place the JSON inside ./auth
# and set one of the paths below to the container path.
# GOOGLE_APPLICATION_CREDENTIALS=/app/auth/earth-engine-service-account.json
# EE_CREDENTIALS_PATH=/app/auth/earth-engine-service-account.json
# EE_SERVICE_ACCOUNT_EMAIL=service-account@project.iam.gserviceaccount.com
